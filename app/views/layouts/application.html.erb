<!DOCTYPE html>
<html lang="en">
  <head>
    <%# Fallback title only when SSR is unavailable (Inertia SSR provides its own) %>
    <% unless inertia_ssr_head.present? %><title>ContextQMD</title><% end %>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#09090B">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="application-name" content="ContextQMD">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= vite_stylesheet_tag "application" %>
    <% if Rails.env.development? %>
      <script>
        (() => {
          const reloadKey = "vite-dev-recovery-at"
          const shouldReload = () => {
            const lastAttempt = Number(sessionStorage.getItem(reloadKey) || "0")
            return Date.now() - lastAttempt > 10000
          }
          const reloadOnce = () => {
            if (!shouldReload()) return
            sessionStorage.setItem(reloadKey, String(Date.now()))
            window.location.reload()
          }
          const isStaleViteDep = (value) =>
            typeof value === "string" &&
            value.includes("/vite-dev/@fs/") &&
            value.includes("/node_modules/.vite/deps/")

          window.addEventListener(
            "error",
            (event) => {
              const source =
                event.filename ||
                event.target?.src ||
                event.target?.href ||
                ""

              if (isStaleViteDep(source)) reloadOnce()
            },
            true
          )

          window.addEventListener("unhandledrejection", (event) => {
            const message = String(event.reason?.message || event.reason || "")
            if (
              message.includes("WebSocket closed without opened") ||
              message.includes("Outdated Optimize Dep")
            ) {
              reloadOnce()
            }
          })
        })()
      </script>
    <% end %>
    <%= vite_react_refresh_tag %>
    <%= vite_client_tag %>
    <%= vite_typescript_tag "inertia.tsx" %>
    <script>
      window.analyticsConfig = <%= raw(
        Analytics::TrackerBootstrap.build(
          request: request,
          initial_pageview_tracked: analytics_initial_pageview_tracked?,
          initial_page_key: analytics_initial_page_key
        ).to_json
      ) %>;
    </script>
    <script src="<%= analytics_tracker_script_path %>" defer></script>
    <%= inertia_ssr_head %>

  </head>

  <body>
    <%= yield %>
  </body>
</html>
