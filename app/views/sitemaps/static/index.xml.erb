<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
<% today = Time.current.beginning_of_day.iso8601 %>
<% %w[/ /libraries /rankings /about /privacy /terms /contact].each do |path| %>
  <url>
    <loc><%= @host %><%= path %></loc>
    <lastmod><%= today %></lastmod>
  </url>
<% end %>
</urlset>
