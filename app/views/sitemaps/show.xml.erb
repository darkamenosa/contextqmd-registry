<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc><%= @host %>/</loc>
  </url>
  <url>
    <loc><%= @host %>/libraries</loc>
  </url>
  <url>
    <loc><%= @host %>/rankings</loc>
  </url>
<% @static_pages.each do |slug| %>
  <url>
    <loc><%= @host %>/<%= slug %></loc>
  </url>
<% end %>
<% @libraries.each do |lib| %>
  <url>
    <loc><%= @host %>/libraries/<%= lib.slug %></loc>
    <lastmod><%= lib.updated_at.iso8601 %></lastmod>
  </url>
<% end %>
</urlset>
