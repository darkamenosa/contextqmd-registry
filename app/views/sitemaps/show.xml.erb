<?xml version="1.0" encoding="UTF-8"?>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
<% @sitemaps.each do |sitemap| %>
  <sitemap>
    <loc><%= sitemap[:loc] %></loc>
<% if sitemap[:lastmod] %>
    <lastmod><%= sitemap[:lastmod].iso8601 %></lastmod>
<% end %>
  </sitemap>
<% end %>
</sitemapindex>
