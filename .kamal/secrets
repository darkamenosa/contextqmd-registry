# Kamal secrets — each line evaluated independently (no shell state carries over).
# Use grep from .env for each secret.

KAMAL_REGISTRY_PASSWORD=$(grep '^KAMAL_REGISTRY_PASSWORD=' .env | cut -d= -f2-)
RAILS_MASTER_KEY=$(cat config/master.key)
POSTGRES_PASSWORD=$(grep '^POSTGRES_PASSWORD=' .env | cut -d= -f2-)
CLOUDFLARE_R2_ACCESS_KEY_ID=$(grep '^CLOUDFLARE_R2_ACCESS_KEY_ID=' .env | cut -d= -f2-)
CLOUDFLARE_R2_SECRET_ACCESS_KEY=$(grep '^CLOUDFLARE_R2_SECRET_ACCESS_KEY=' .env | cut -d= -f2-)
